# Runtime profile
APP_ENV=dev
WEB_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]

# API and database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
NEXT_PUBLIC_UKDE_API_ORIGIN=http://127.0.0.1:8000
UKDE_API_ORIGIN_INTERNAL=http://127.0.0.1:8000
TELEMETRY_LOG_LEVEL=INFO
TELEMETRY_EXPORT_MODE=none
# Internal-only endpoint example:
# TELEMETRY_OTLP_ENDPOINT=http://otel-collector.internal:4318/v1/traces
TELEMETRY_TIMELINE_LIMIT=400
STORAGE_CONTROLLED_RAW_PREFIX=controlled/raw/
STORAGE_CONTROLLED_DERIVED_PREFIX=controlled/derived/
STORAGE_SAFEGUARDED_EXPORTS_PREFIX=safeguarded/exports/

# Internal model-service map contract
OPENAI_BASE_URL=http://127.0.0.1:8010/v1
OPENAI_API_KEY=internal-local-dev
MODEL_DEPLOYMENT_ROOT="~/Library/Application Support/UKDataExtraction/models"
MODEL_ARTIFACT_ROOT="~/Library/Application Support/UKDataExtraction/models"
MODEL_CATALOG_PATH=infra/models/catalog.phase-0.1.json
MODEL_ALLOWLIST=["TRANSCRIPTION_PRIMARY","ASSIST","PRIVACY_NER","PRIVACY_RULES","TRANSCRIPTION_FALLBACK","EMBEDDING_SEARCH"]
MODEL_SERVICE_MAP_PATH=infra/models/service-map.phase-0.1.json
OUTBOUND_ALLOWLIST=["localhost","127.0.0.1","::1",".internal",".local"]
MODEL_WARM_START=true
MODEL_STARTUP_VALIDATION_MODE=warn

# Security headers and hardening defaults
SECURITY_CSP_MODE=enforce
SECURITY_CSP_VALUE=default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http: https:
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()
# Optional operational signal for /admin/security/status
# SECURITY_LAST_BACKUP_AT=2026-01-01T00:00:00+00:00
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=30
PROTECTED_RATE_LIMIT_WINDOW_SECONDS=60
PROTECTED_RATE_LIMIT_MAX_REQUESTS=300

# Shell diagnostics badges
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_ACCESS_TIER=CONTROLLED

# Session boundary and auth
AUTH_SESSION_SECRET=ukde-dev-session-secret-change-me
AUTH_SESSION_TTL_SECONDS=3600
AUTH_COOKIE_NAME=ukde_session
AUTH_CSRF_COOKIE_NAME=ukde_csrf

# Explicit local dev auth mode (must remain false outside dev/test)
AUTH_DEV_MODE_ENABLED=true
AUTH_DEV_SEED_USERS=[{"key":"project-lead","oidc_sub":"dev-project-lead-001","email":"project-lead@local.ukde","display_name":"Dev Project Lead","platform_roles":[]},{"key":"researcher","oidc_sub":"dev-researcher-001","email":"researcher@local.ukde","display_name":"Dev Researcher","platform_roles":[]},{"key":"reviewer","oidc_sub":"dev-reviewer-001","email":"reviewer@local.ukde","display_name":"Dev Reviewer","platform_roles":[]},{"key":"admin","oidc_sub":"dev-admin-001","email":"admin@local.ukde","display_name":"Dev Admin","platform_roles":["ADMIN"]},{"key":"auditor","oidc_sub":"dev-auditor-001","email":"auditor@local.ukde","display_name":"Dev Auditor","platform_roles":["AUDITOR"]}]
WORKER_QUEUE_NAME=ukde-jobs
WORKER_HEARTBEAT_SECONDS=30
WORKER_POLL_SECONDS=2
WORKER_MAX_ITERATIONS=0
# WORKER_ID=worker-local

# Real OIDC path (leave unset for local dev fixtures)
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
# OIDC_SCOPES=openid profile email
# OIDC_POST_LOGIN_REDIRECT_PATH=/projects
# OIDC_POST_LOGOUT_REDIRECT_PATH=/login
